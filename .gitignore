# ==========================
# 🐍 Python 編譯與暫存檔 (必填)
# ==========================
__pycache__/
*.py[cod]
*$py.class

# ==========================
# 📦 虛擬環境 (Virtual Environments)
# ==========================
venv/
env/
.venv/
.env/

# ==========================
# 🔑 敏感資料與環境變數 
# ==========================
.env
.env.local
config_local.py
secrets.py

# ==========================
# 📊 專案資料與日誌
# 爬蟲抓下來的 csv/json 或 log 檔通常很大
# ==========================
*.log
logs/
*.csv
*.xlsx
*.json
*.sql
*.sqlite3

# ==========================
# 下載資料夾忽略
# ==========================
data/
downloads/
output_data/

# ==========================
# 🛠 IDE 設定檔 (通常建議忽略)
# ==========================
.vscode/
.idea/
*.swp

# ==========================
# 🖥 作業系統垃圾檔
# ==========================
.DS_Store
Thumbs.db
*.ipynb
.ipynb_checkpoints/